<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        android:elevation="4dp"
        android:layout_marginTop="24dp"
        app:theme="@style/ThemeOverlay.AppCompat.Dark"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvConnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚪ Dispositivo offline"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnRiprova"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riprova"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvAllerte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#33FF0000"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POSIZIONE SEMAFORO"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvNomeIncrocio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Incrocio Sconosciuto"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:id="@+id/tvCodiceSeriale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seriale: --"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="6dp"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardRossa"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        app:cardCornerRadius="13dp"
                        app:cardBackgroundColor="#55FF0000"
                        app:cardElevation="0dp"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardGialla"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        app:cardCornerRadius="13dp"
                        app:cardBackgroundColor="#55FFFF00"
                        app:cardElevation="0dp"
                        android:layout_marginTop="6dp"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardVerde"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        app:cardCornerRadius="13dp"
                        app:cardBackgroundColor="#5500FF00"
                        app:cardElevation="0dp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMPERATURA" android:textColor="#888888" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvTemperatura" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#FFFFFF" android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UMIDITÀ" android:textColor="#888888" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvUmidita" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#FFFFFF" android:textSize="22sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LUMINOSITÀ" android:textColor="#888888" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvLuminosita" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#FFFFFF" android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRAFFICO" android:textColor="#888888" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvTraffico" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#FFFFFF" android:textSize="22sp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pannelloControllo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PANNELLO DI CONTROLLO"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <Button
                        android:id="@+id/btnAccendiSemaforo"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="Accendi"
                        android:textSize="11sp"
                        android:backgroundTint="#2E4A31"
                        android:textColor="#E0E0E0"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnInattivoSemaforo"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="Iattivo"
                        android:textSize="11sp"
                        android:backgroundTint="#5E4823"
                        android:textColor="#E0E0E0"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnSpegniSemaforo"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="Spegni"
                        android:textSize="11sp"
                        android:backgroundTint="#5E2B2B"
                        android:textColor="#E0E0E0"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>