<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        android:elevation="4dp"
        android:layout_marginTop="24dp"
        app:theme="@style/ThemeOverlay.AppCompat.Dark"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STATO CONNESSIONE -->
            <TextView
                android:id="@+id/tvConnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚪ Dispositivo offline"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnRiprova"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riprova"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- SCHEDA INFORMAZIONI SEMAFORO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POSIZIONE SEMAFORO"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvNomeIncrocio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Incrocio Sconosciuto"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvCodiceSeriale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seriale: --"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- SCHEDA STATO ATTUALE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODALITÀ ATTUALE"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStatoSemaforo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In attesa di dati..."
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:layout_marginTop="4dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- SCHEDA SENSORI (Temp/Umidità per l'hardware) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TEMP. SCHEDA"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvTemperatura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UMIDITÀ"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvUmidita"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- PULSANTI DI CONTROLLO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANNELLO DI CONTROLLO"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnAccendiSemaforo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="ATTIVA SEMAFORO"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnInattivoSemaforo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="MODALITÀ INATTIVA (GIALLO LAMPEGGIANTE)"
                android:backgroundTint="#F57F17"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSpegniSemaforo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="SPEGNI SEMAFORO"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnProva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modalità Prova MQTT"
                android:backgroundTint="#333333"
                android:textColor="#AAAAAA"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>